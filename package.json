{
  "name": "lob-mcp",
  "version": "0.1.4",
  "description": "MCP server for the Lob.com API - 70 tools for address verification, postcards, letters, self-mailers, checks, templates, campaigns, and webhooks.",
  "type": "module",
  "bin": {
    "lob-mcp": "build/index.js"
  },
  "files": [
    "build"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "prepare": "npm run build",
    "typecheck": "tsc --noEmit",
    "inspector": "npx @modelcontextprotocol/inspector build/index.js",
    "start": "node build/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "pdf-lib": "^1.17.1",
    "typescript": "^5.6.3"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "lob",
    "lob-api",
    "direct-mail",
    "address-verification",
    "postcards",
    "letters",
    "checks",
    "self-mailers",
    "claude",
    "ai",
    "anthropic"
  ],
  "author": "Optimize Overseas",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/optimize-overseas/lob-mcp.git"
  },
  "homepage": "https://github.com/optimize-overseas/lob-mcp#readme",
  "bugs": {
    "url": "https://github.com/optimize-overseas/lob-mcp/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
